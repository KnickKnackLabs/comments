#!/usr/bin/env nu
#MISE description="Print current directive context"
#MISE dir="{{config_root}}"
#USAGE arg "[field]" default="" help="Context field: location, file, line, column, directive, or script"
#USAGE flag "--json" default=#false help="Emit JSON"
#USAGE example "mise run context" header="Print the current directive location"
#USAGE example "mise run context directive --json" header="Print the current directive record as JSON"

use ../../lib/comments/context.nu [context-field]

let field = $env.usage_field
let json = ($env.usage_json == "true")
let raw_context = ($env.COMMENTS_CONTEXT_JSON? | default "")

if ($raw_context | str trim | is-empty) {
  print -e "comments context: COMMENTS_CONTEXT_JSON is not set; this command only works while dispatching a directive"
  exit 1
}

let context = try {
  $raw_context | from json
} catch {
  print -e "comments context: COMMENTS_CONTEXT_JSON is not valid JSON"
  exit 1
}

let value = if (($field | str trim | is-empty) and $json) {
  $context
} else {
  context-field $context $field
}

if $json {
  print ($value | to json -r)
} else {
  print $value
}
