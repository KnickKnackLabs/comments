#!/usr/bin/env nu
#MISE description="Extract comment directives from a file"
#MISE hide=true
#MISE dir="{{config_root}}"
#USAGE arg "file" help="File to scan for directives"
#USAGE example "mise run directives README.md" header="Extract directives from a file"

use ../../lib/comments/extract.nu [extract-comments is-supported-target resolve-target supported-extension-message]
use ../../lib/comments/directives.nu directive-from-comment

let file = $env.usage_file
let base = ($env.COMMENTS_CALLER_PWD? | default $env.PWD)
let target = (resolve-target $file $base)

if (($target | path type) != "file") {
  print -e $"comments directives: file not found: ($file)"
  exit 1
}

if not (is-supported-target $target) {
  print -e $"comments directives: (supported-extension-message $target)"
  exit 1
}

for comment in (extract-comments $target) {
  let directive = (directive-from-comment $comment)

  if $directive != null {
    print ($directive | to json -r)
  }
}
