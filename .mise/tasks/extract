#!/usr/bin/env nu
#MISE description="Extract comment-like nodes from a file"
#MISE hide=true
#MISE dir="{{config_root}}"
#USAGE arg "file" help="File to scan for comments"
#USAGE example "mise run extract README.md" header="Extract comment nodes from a file"

let file = $env.usage_file
let base = ($env.COMMENTS_CALLER_PWD? | default $env.PWD)
let target = if ($file | str starts-with "/") { $file } else { [$base $file] | path join }

if (($target | path type) != "file") {
  print -e $"comments extract: file not found: ($file)"
  exit 1
}

# ast-grep auto-detects the language from the file extension, but tree-sitter
# grammars do not normalize comment node names. This list scales by known
# comment-like node kind, not by language. Add kinds here as we encounter
# grammars whose comments use a different node name.
let kinds = [comment line_comment block_comment html_block]

let query_results = (
  $kinds
  | each {|kind|
      let result = (^ast-grep run --kind $kind --json=stream $target | complete)
      let ok = ($result.exit_code == 0)
      let matches = if ($ok and ($result.stdout | str trim | is-not-empty)) {
        $result.stdout
        | lines
        | where {|line| ($line | str trim | is-not-empty) }
        | each {|line| $line | from json | insert kind $kind }
      } else { [] }

      {kind: $kind, ok: $ok, matches: $matches}
    }
)

let successful_queries = ($query_results | where ok == true | length)
if $successful_queries == 0 {
  print -e $"comments extract: no known ast-grep comment node kind for file: ($file)"
  exit 1
}

let matches = ($query_results | where ok == true | get matches | flatten)
if (($matches | length) == 0) {
  exit 0
}

let deduped = (
  $matches
  | insert __key {|row| $"($row.file):($row.range.byteOffset.start):($row.range.byteOffset.end)" }
  | uniq-by __key
  | sort-by range.byteOffset.start
  | reject __key
)

for row in $deduped {
  print ($row | to json -r)
}
